    },
    "config.general.distance_mode_tooltip": {
        "en_at_translation": "Absolute distance means the tool moves to specified coordinates.<br>Relative distance means the tool moves from its current position <br>-by- the specified distance. (Relative is rarely used in modern CNC.)<br>This setting applies primarily to g-code files. Relative can be <br>applied if needed in an OpenSBP file by using the [SR] command.<br>"
    },
