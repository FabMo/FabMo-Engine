    "config.general.machine_name_tooltip": {
        "en_at_translation": "The name of your tool. The tool name will be displayed on the dashboard.<br>It is used as the Wifi name for AP mode and IP address display.<br>You can change the name here. The display will update the next time<br>you start the software.<br>"
    },
